# ============================================================
# MindMate Production Environment Variables
# ============================================================

# --- Supabase Config ---
# Get these from Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_SERVER_ONLY

# --- AI Config (Groq) ---
# Get from console.groq.com
GROQ_API_KEY=your_groq_api_key

# --- Push Notifications (VAPID) ---
# Generate using `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_key
VAPID_PRIVATE_KEY=your_private_key

# --- PWA Config ---
# Set to 'production' to enable service worker
NODE_ENV=development

# --- App URL ---
# Used for absolute links in reports/emails
NEXT_PUBLIC_APP_URL=http://localhost:3000
